      "prompt": "Give an example of when you would use lock off devices.",
      "points": 5,
      "expectedKeywords": ["maintenance", "repair", "isolate", "power", "electrical"]
    },
    {
      "id": "q7_control_fume",
      "type": "fill_in_the_blank",
      "prompt": "Give an example of when you would use fume extraction.",
